# LLM
GROQ_API_KEY=your_groq_api_key

# Whisper (Groq): whisper-large-v3-turbo | whisper-large-v3
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGE=ru
WHISPER_TEMPERATURE=0
# Словарь для prompt (русский текст, через запятую — свои компании/имена)
# WHISPER_PROMPT=...
# Нормализация ffmpeg: 16 kHz mono + фильтры (нужен ffmpeg в PATH)
WHISPER_FFMPEG_PREPROCESS=1
# WHISPER_FFMPEG_PATH=ffmpeg
# WHISPER_FFMPEG_AF=highpass=f=80,loudnorm=I=-16:TP=-1.5:LRA=11

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
HERMES_MODEL=hermes3:latest

# Database
DATABASE_URL=postgresql+asyncpg://smartcrm:smartcrm@localhost:5432/smartcrm

# Redis
REDIS_URL=redis://localhost:6379

# Search
BRAVE_API_KEY=your_brave_api_key
TAVILY_API_KEY=your_tavily_api_key
SERPER_API_KEY=your_serper_api_key

# Лидогенерация
CHECKO_API_KEY=MXoenGKRZ0QJlXvE
HUNTER_API_KEY=your_hunter_api_key
APOLLO_API_KEY=your_apollo_api_key
BUILTWITH_API_KEY=d7d3aada-840c-4dcd-96af-8549e43bb76d
NEWS_API_KEY=26b947400536426a9aeeb6edfe85f1c5
BUSTER_API_KEY=your_buster_api_key
FNS_API_KEY=e4fb4b0495eb79ed9d614d3f0c8da15453245bee

# Chroma RAG (локальная персистентность; не сервер CHROMA_HOST)
CHROMA_PERSIST_DIR=data/chroma_db
RAG_ENABLED=1
RAG_TOP_K=5
RAG_CHUNK_MAX_CHARS=1800
RAG_CHUNK_MIN_CHARS=400
RAG_OVERLAP_SENTENCES=2
RAG_XLSX_ROWS_PER_BLOCK=12
# PDF: в venv обязательно pip install pypdf (или PyPDF2 как запасной вариант)

# Битрикс24 (входящий вебхук: CRM + user; базовый URL до секрета, со слэшем в конце)
# Пример: https://ваш-портал/rest/112/ваш_секрет/
BITRIX24_WEBHOOK_URL=

# App
APP_SECRET_KEY=change_me_in_production
DEBUG=true
